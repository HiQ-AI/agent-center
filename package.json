{
  "name": "@hiq-ai/agent-center",
  "version": "0.0.4",
  "description": "Agent Center connector — register personal agents, discover capabilities, exchange durable messages, and delegate A2A v1 Tasks.",
  "type": "module",
  "bin": {
    "agent-center-mcp": "dist/server.js",
    "agent-center": "dist/cli.js",
    "agent-center-codex": "dist/codexAdapter.js",
    "agent-center-openclaw": "dist/openclawAdapter.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HiQ-AI/agent-center.git"
  },
  "homepage": "https://github.com/HiQ-AI/agent-center#readme",
  "bugs": {
    "url": "https://github.com/HiQ-AI/agent-center/issues"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.md",
    "integrations"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/server.ts",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "Apache-2.0"
}
